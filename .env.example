# Copiez ce fichier en .env et remplissez les valeurs avant de démarrer.
# Ne commitez jamais le fichier .env dans un dépôt git.

# Clé secrète pour les sessions Express (chaîne aléatoire longue, min 32 caractères)
SESSION_SECRET=changez-moi-avec-une-valeur-aleatoire-longue

# Port du serveur (optionnel, défaut : 3000)
PORT=3000

# Environnement (production active le cookie secure=true)
# NODE_ENV=production
